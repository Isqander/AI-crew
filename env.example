# ===========================================
# AI-crew Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
# cp env.example .env

# --- Application Settings ---
PROJECT_NAME=AI-crew
VERSION=0.1.0
DEBUG=true

# --- Aegra Configuration ---
AEGRA_CONFIG=./aegra.json
HOST=0.0.0.0
PORT=8000
SERVER_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
POSTGRES_USER=aicrew
POSTGRES_PASSWORD=aicrew_secret_password
POSTGRES_DB=aicrew
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://aicrew:aicrew_secret_password@postgres:5432/aicrew
DATABASE_ECHO=false

# --- Connection Pools ---
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=0
LANGGRAPH_MIN_POOL_SIZE=1
LANGGRAPH_MAX_POOL_SIZE=6

# --- Authentication ---
AUTH_TYPE=noop

# --- Logging ---
LOG_LEVEL=INFO
ENV_MODE=LOCAL

# ===========================================
# LLM Providers (add your API keys)
# ===========================================

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini)
GOOGLE_API_KEY=

# Open-source via Together.ai or Groq
TOGETHER_API_KEY=
GROQ_API_KEY=

# ===========================================
# Observability (Langfuse)
# ===========================================
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# ===========================================
# GitHub Integration
# ===========================================
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_REPO=

# ===========================================
# Frontend
# ===========================================
VITE_API_URL=http://localhost:8000
