# ===========================================
# AI-crew Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
# cp env.example .env

# --- Application Settings ---
PROJECT_NAME=AI-crew
VERSION=0.1.0
DEBUG=true

# --- Aegra Configuration ---
AEGRA_CONFIG=./aegra.json
HOST=0.0.0.0
PORT=8000
SERVER_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
POSTGRES_USER=aicrew
POSTGRES_PASSWORD=aicrew_secret_password
POSTGRES_DB=aicrew
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://aicrew:aicrew_secret_password@postgres:5432/aicrew
DATABASE_ECHO=false

# --- Connection Pools ---
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=0
LANGGRAPH_MIN_POOL_SIZE=1
LANGGRAPH_MAX_POOL_SIZE=6

# --- Authentication ---
AUTH_TYPE=noop

# --- Logging ---
LOG_LEVEL=INFO
ENV_MODE=LOCAL

# ===========================================
# LLM Configuration (Proxy API)
# ===========================================

# Default API endpoint (OpenAI-compatible)
LLM_API_URL=https://clipapi4me.31.59.58.143.nip.io/v1
LLM_API_KEY=your-api-key-here

# --- Additional endpoints (optional) ---
# You can define multiple endpoints with naming convention:
# LLM_<NAME>_URL and LLM_<NAME>_KEY
# Example:
# LLM_BACKUP_URL=https://other-api.example.com/v1
# LLM_BACKUP_KEY=backup-api-key

# --- Default model (optional, used when role not specified) ---
# LLM_DEFAULT_MODEL=claude-sonnet-4-5-thinking

# --- Per-agent model overrides (optional) ---
# Uncomment to override default models for specific agents:
# LLM_MODEL_PM=claude-sonnet-4-5-thinking
# LLM_MODEL_ANALYST=claude-sonnet-4-5-thinking
# LLM_MODEL_ARCHITECT=claude-opus-4-5-thinking
# LLM_MODEL_DEVELOPER=gemini-3-pro-high
# LLM_MODEL_QA=gemini-3-flash-preview

# Available models:
# - claude-opus-4-5-thinking (most capable, for complex architecture)
# - claude-sonnet-4-5-thinking (balanced, for analysis and PM tasks)
# - gemini-3-pro-high (code generation)
# - gemini-3-flash-preview (fast, for QA and simple tasks)
# - glm-4.7 (alternative)

# ===========================================
# Observability (Langfuse)
# ===========================================
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# ===========================================
# GitHub Integration
# ===========================================
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_REPO=

# ===========================================
# Frontend
# ===========================================
VITE_API_URL=http://localhost:8000
